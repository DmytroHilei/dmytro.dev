---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Dmytro Hilei',
  description = 'ML/HPC engineering student at TalTech',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@500;600&display=swap" rel="stylesheet" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
  }

  :root {
    --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
    --font-mono: 'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
  }

  html {
    background: #ffffff;
    color: #1f1f1f;
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
  }

  body {
    margin: 0 auto;
    padding: 2.5rem 0.9rem 4rem;
    max-width: 720px;
  }

  a {
    color: #1f1f1f;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: #cfcfcf;
    transition: color 0.1s, text-decoration-color 0.1s;
  }

  a:hover {
    color: #000;
    text-decoration-color: #666;
  }

  p {
    margin: 0 0 0.9em;
  }

  ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }
</style>
