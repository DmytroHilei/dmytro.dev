---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main>

    <header>
      <div class="header-left">
        <img src="/profile.jpg" alt="Dmytro Hilei" class="avatar" />
        <nav class="socials" aria-label="Social links">
          <a href="https://github.com/DmytroHilei" target="_blank" rel="noopener" aria-label="GitHub">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/in/dmytro-hilei-1092b3287/" target="_blank" rel="noopener" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="mailto:dmytrohilei@gmail.com" aria-label="Email">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z"/>
              <path d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z"/>
            </svg>
          </a>
        </nav>
      </div>
      <div class="header-text">
        <h1>Dmytro Hilei</h1>
        <p class="tagline">ML + HPC + embedded systems · TalTech, Tallinn</p>
      </div>
    </header>

    <section class="bio">
      <p>
        I work at the level where algorithms meet hardware — CUDA kernels, memory hierarchies,
        parallelism. Currently studying integrated engineering at TalTech. My focus is not just
        training models but understanding and optimizing what happens underneath.
      </p>
    </section>

    <section class="projects">
      <h2>projects</h2>
      <ul>
        <li>
          <div class="proj-header">
            <span class="proj-name">OpenCV StereoSGM CUDA</span>
            <div class="proj-tags">
              <span class="tag">CUDA / HPC</span>
              <span class="tag tag-status">in progress</span>
            </div>
          </div>
          <p>
            Optimizing OpenCV's Semi-Global Matching pipeline for NVIDIA Blackwell (sm_120, RTX 5060),
            under a mentor. Profiled with Nsight Compute, fixed two correctness bugs, tried a handful
            of optimizations that haven't moved the needle yet. Next: ping-pong tiling for the WTA
            kernel via TMA. If the speedups hold up end-to-end, I'll upstream a PR to opencv/opencv.
          </p>
          <a class="proj-link" href="https://github.com/DmytroHilei/opencv" target="_blank" rel="noopener">github ↗</a>
        </li>

        <li>
          <div class="proj-header">
            <span class="proj-name">GPT Music Transformer</span>
            <div class="proj-tags">
              <span class="tag">ML</span>
            </div>
          </div>
          <p>
            Rewrote an LSTM music generation model into a decoder-only Transformer (~20M params:
            6 layers, 8 heads, 512 dim, 1024 context). Pretrained on Maestro and GiantMIDI-Piano
            with REMI tokenization, then finetuned on a corpus of Ukrainian folk songs. Trained
            on a rented RTX 5090 via vast.ai.
          </p>
          <a class="proj-link" href="https://github.com/DmytroHilei/Music_generative_model" target="_blank" rel="noopener">github ↗</a>
        </li>

        <li>
          <div class="proj-header">
            <span class="proj-name">License Plate OCR</span>
            <div class="proj-tags">
              <span class="tag">ML / CV</span>
            </div>
          </div>
          <p>
            End-to-end pipeline: YOLO for plate detection, custom CRNN with CTC loss for text
            recognition. Trained on a custom-collected dataset of Estonian plate crops.
          </p>
          <a class="proj-link" href="https://github.com/DmytroHilei/YOLO_training_on_plates_and_customeOCR" target="_blank" rel="noopener">github ↗</a>
        </li>

        <li>
          <div class="proj-header">
            <span class="proj-name">Speech Recognition on Raspberry Pi 5</span>
            <div class="proj-tags">
              <span class="tag">ML / Edge</span>
            </div>
          </div>
          <p>
            Early on-device keyword recognizer running on a Pi 5. Roadmap: scale to a much larger
            dataset, swap the front-end for a ViT operating on log-mel spectrograms, broaden the
            command vocabulary, and finetune on my own voice.
          </p>
          <a class="proj-link" href="https://github.com/DmytroHilei/Speech_Recognition_on_rasberry_pi_5" target="_blank" rel="noopener">github ↗</a>
        </li>

        <li>
          <div class="proj-header">
            <span class="proj-name">2D Heat & Wave Sim</span>
            <div class="proj-tags">
              <span class="tag">HPC / Sim</span>
            </div>
          </div>
          <p>
            Stencil-based finite-difference simulations of 2D heat diffusion and wave propagation —
            same kernel pattern, combined into one project. Hand-tuned C++/OpenMP (cache-aware 4×4
            tiling, single precision, contiguous arrays) and a CUDA rewrite for RTX 5060,
            benchmarked against a reference PyTorch implementation.
          </p>
          <table class="bench">
            <thead>
              <tr><th></th><th>OpenMP</th><th>CUDA</th><th>CUDA tiled</th><th>PyTorch</th></tr>
            </thead>
            <tbody>
              <tr><th scope="row">heat</th><td>15.43s</td><td>1.40s</td><td>2.10s</td><td>10.00s</td></tr>
              <tr><th scope="row">wave</th><td>4.54s</td><td>0.40s</td><td>—</td><td>0.194s</td></tr>
            </tbody>
          </table>
          <p class="bench-note">
            Tiled heat regresses: heavy branching in the staging path defeats coalescing, and the
            stencil doesn't really reward shared-memory tiling at this grid size. Would want
            CUTE/CUTLASS to do it cleanly.
          </p>
          <a class="proj-link" href="https://github.com/DmytroHilei/2D_heat_diffusion_and_wave_propagation" target="_blank" rel="noopener">github ↗</a>
        </li>

        <li>
          <div class="proj-header">
            <span class="proj-name">SmartBinaryClock</span>
            <div class="proj-tags">
              <span class="tag">Embedded</span>
            </div>
          </div>
          <p>
            Embedded C++ project displaying time in binary and military formats alongside
            temperature, humidity, and voltage readings.
          </p>
          <a class="proj-link" href="https://github.com/DmytroHilei/SmartBinaryClock" target="_blank" rel="noopener">github ↗</a>
        </li>
      </ul>
    </section>

    <section class="skills">
      <h2>skills</h2>
      <dl>
        <dt>spoken</dt>
        <dd>Ukrainian (native) · English (fluent, IELTS 6.5) · Estonian (A1.1, studying)</dd>

        <dt>languages</dt>
        <dd>C++ · CUDA · C · Python</dd>

        <dt>ml</dt>
        <dd>transformers (decoder-only GPT, DETR) · RNNs · LSTMs · CNNs · ResNet · detection · OCR</dd>

        <dt>hpc</dt>
        <dd>OpenMP · CUDA · TMA · CUTLASS basics · classical CV kernel tuning</dd>

        <dt>tools</dt>
        <dd>PyTorch · NumPy · OpenCV · Matplotlib · Git · LaTeX</dd>
      </dl>
    </section>

    <section class="timeline">
      <h2>education</h2>
      <ul>
        <li>
          <span class="when">2025 — 2028</span>
          <div class="what">
            <strong>Tallinn University of Technology</strong>
            <span>Integrated Engineering BSc. GPA 4.8/5 (semester 1).</span>
          </div>
        </li>
        <li>
          <span class="when">2026 — 2030</span>
          <div class="what">
            <strong>Lviv Polytechnic National University</strong>
            <span>Parallel enrollment, planned.</span>
          </div>
        </li>
        <li>
          <span class="when">2025</span>
          <div class="what">
            <strong>Lviv Physics and Mathematics Lyceum</strong>
            <span>Graduated. GPA 10.8/12.</span>
          </div>
        </li>
      </ul>
    </section>

    <section class="timeline">
      <h2>awards</h2>
      <ul>
        <li>
          <span class="when">2025</span>
          <div class="what">
            <span>Silver Medal, International Olympiad on Astronomy and Astrophysics</span>
          </div>
        </li>
        <li>
          <span class="when">2024</span>
          <div class="what">
            <span>Bronze Medal, International Olympiad on Astronomy and Astrophysics</span>
          </div>
        </li>
        <li>
          <span class="when">2024 — 2025</span>
          <div class="what">
            <span>First-stage diplomas, All-Ukrainian Olympiads in Astronomy & Astrophysics</span>
          </div>
        </li>
        <li>
          <span class="when">2023</span>
          <div class="what">
            <span>Silver Medal, IOAA Junior (under-16 category)</span>
          </div>
        </li>
      </ul>
    </section>

    <section class="timeline">
      <h2>volunteering</h2>
      <ul>
        <li>
          <span class="when">2018 —</span>
          <div class="what">
            <strong><a href="https://plast.org.ua/" target="_blank" rel="noopener">Plast</a></strong>
            <span>Ukrainian national scouting organization, 7 years.</span>
          </div>
        </li>
        <li>
          <span class="when">2025 —</span>
          <div class="what">
            <strong>Ukrainian Astronomy Olympiads</strong>
            <span>Jury member and lecturer (while still competing).</span>
          </div>
        </li>
      </ul>
    </section>

  </main>
</Layout>

<style>
  main {
    display: flex;
    flex-direction: column;
    gap: 2.75rem;
  }

  /* Header with photo */
  header {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
  }

  .header-left {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.7rem;
    flex-shrink: 0;
  }

  .avatar {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    object-fit: cover;
    background: #f0f0f0;
    border: 1px solid #e6e6e6;
  }

  .header-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
    padding-top: 0.25rem;
  }

  h1 {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 1.2rem;
    font-weight: 600;
    color: #0a0a0a;
    letter-spacing: -0.02em;
  }

  .tagline {
    margin: 0;
    color: #6a6a6a;
    font-size: 0.9rem;
  }

  .now {
    margin: 0.45rem 0 0;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: #6a6a6a;
    line-height: 1.5;
  }

  .now-label {
    color: #0a0a0a;
    padding: 0.05em 0.4em;
    background: #f1f1f1;
    border-radius: 3px;
    margin-right: 0.4em;
    font-weight: 500;
  }

  .socials {
    display: flex;
    gap: 0.7rem;
  }

  .socials a {
    color: #6a6a6a;
    display: inline-flex;
    text-decoration: none;
    line-height: 0;
  }

  .socials a:hover {
    color: #0a0a0a;
  }

  .socials svg {
    width: 17px;
    height: 17px;
    fill: currentColor;
  }

  /* Bio */
  .bio p {
    margin: 0;
    color: #2a2a2a;
    font-size: 0.95rem;
  }

  /* Section labels (mono lowercase) */
  h2 {
    margin: 0 0 1.15rem;
    font-family: var(--font-mono);
    font-size: 1.15rem;
    font-weight: 600;
    color: #0a0a0a;
    letter-spacing: -0.01em;
  }

  /* Timeline (education, awards) */
  .timeline ul {
    display: grid;
    grid-template-columns: max-content 1fr;
    column-gap: 1.5rem;
    row-gap: 0.9rem;
  }

  .timeline li {
    display: contents;
  }

  .when {
    color: #888;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    white-space: nowrap;
    padding-top: 0.1rem;
    font-variant-numeric: tabular-nums;
  }

  .what {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    color: #444;
    font-size: 0.9rem;
  }

  .what strong {
    color: #0a0a0a;
    font-weight: 600;
  }

  /* Projects (grid of cells) */
  .projects ul {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.85rem;
  }

  .projects li {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding: 1.1rem 1.15rem;
    border: 1px solid #ececec;
    border-radius: 4px;
    transition: border-color 0.15s, background 0.15s;
  }

  .projects li:hover {
    border-color: #d4d4d4;
    background: #fafafa;
  }

  .proj-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .proj-name {
    color: #0a0a0a;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .proj-tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
    flex-shrink: 0;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: #666;
    background: #f3f3f3;
    padding: 0.1em 0.45em;
    border-radius: 3px;
    line-height: 1.5;
  }

  .tag-status {
    color: #8a5a00;
    background: #fdf3df;
  }

  .projects p {
    margin: 0;
    color: #3a3a3a;
    font-size: 0.875rem;
    line-height: 1.55;
    flex: 1;
  }

  .proj-link {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    color: #6a6a6a;
    text-decoration-color: #d0d0d0;
    align-self: flex-start;
    margin-top: 0.15rem;
  }

  .proj-link:hover {
    color: #0a0a0a;
    text-decoration-color: #666;
  }

  /* Inline list (stack, languages) */
  .inline-list p {
    margin: 0;
    color: #3a3a3a;
    font-size: 0.9rem;
    font-family: var(--font-mono);
  }

  /* Skills (categorized) */
  .skills dl {
    display: grid;
    grid-template-columns: max-content 1fr;
    column-gap: 1.5rem;
    row-gap: 0.55rem;
    margin: 0;
  }

  .skills dt {
    color: #888;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding-top: 0.1rem;
  }

  .skills dd {
    margin: 0;
    color: #3a3a3a;
    font-size: 0.9rem;
  }

  /* Benchmark table inside a project */
  .bench {
    border-collapse: collapse;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    margin-top: 0.15rem;
    font-variant-numeric: tabular-nums;
  }

  .bench th, .bench td {
    padding: 0.18rem 0.85rem 0.18rem 0;
    text-align: left;
    font-weight: 400;
  }

  .bench thead th {
    color: #888;
    border-bottom: 1px solid #ececec;
    padding-bottom: 0.3rem;
  }

  .bench tbody th {
    color: #0a0a0a;
    font-weight: 600;
  }

  .bench tbody td {
    color: #3a3a3a;
  }

  .bench-note {
    margin: 0.5rem 0 0;
    color: #6a6a6a;
    font-size: 0.82rem;
    line-height: 1.55;
    font-style: italic;
  }

  @media (max-width: 600px) {
    .projects ul {
      grid-template-columns: 1fr;
    }
  }

  code {
    font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, monospace;
    font-size: 0.85em;
    color: #2a2a2a;
    background: #f4f4f4;
    padding: 0.05em 0.3em;
    border-radius: 3px;
  }

  /* Mobile */
  @media (max-width: 480px) {
    .timeline ul {
      grid-template-columns: 1fr;
      row-gap: 1.25rem;
    }

    .timeline li {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
    }

    .when {
      font-size: 0.78rem;
    }
  }
</style>
